# Option 1: Login credentials (recommended)
TL_USERNAME="your_username"
TL_PASSWORD="your_password"

# Option 2: Cookie string (alternative — skip login)
# Get from: Browser DevTools (F12) > Network tab > any TL request > Cookie header
# TL_COOKIES="tluid=XXXX; tlpass=XXXX; tlcc=XXXX"

# Analysis constraints (used by analyze_and_generate_filters.py)
STORAGE_TB=4                  # Seedbox storage capacity in TB
MIN_TORRENT_AGE_DAYS=3        # Exclude torrents younger than this from analysis
MAX_SEED_DAYS=10              # Hard delete after this many days
