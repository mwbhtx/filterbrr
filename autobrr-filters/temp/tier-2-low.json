        "release_profile_duplicate": null,
        "except_release_groups": "AKENATON,B0MBARDiERS,CiNEPHiLES,FW,GAZPROM,GuyZo,HDH,KaOs,MALUS,MiMESiS,NorTekst,RAWR,RUT,SPHD,SURCODE,SiCFoI,TMT,TRiToN,TheFarm,Vialle,WOU,XEBEC,ray,seedpool"
